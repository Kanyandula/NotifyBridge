<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!--
      Debug-variant overlay. Android Studio's normal Run action installs the
      debug APK, so the live bridge path must keep MqttForegroundService. Only
      BootReceiver is removed here: instrumented tests run the debug
      app-under-test under HiltTestRunner/HiltTestApplication, and a boot-time
      auto-start can recreate AndroidEntryPoint services in that test process
      before any test has installed a Hilt rule.

      NotifListenerService is intentionally NOT removed: it is bound by the OS
      only AFTER the user grants notification-listener access, which never
      happens in a non-@HiltAndroidTest instrumented run, so it does not hit
      the Hilt-test crash path above. Keeping it in the debug APK is required
      for Settings → Notification access to list the app at all — without it
      the onboarding Step 1 deep-link lands on a picker that does not include
      NotifyBridge and the user cannot proceed.
    -->
    <application>
        <receiver android:name=".service.BootReceiver" tools:node="remove" />
    </application>
</manifest>
